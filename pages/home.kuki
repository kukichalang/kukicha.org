# pages/home.kuki — Landing page composition

import "stdlib/html"

func HomePage() html.Fragment
    nav := Navbar("kukicha", list of NavLink{
        NavLink{label: "Playground", dialogFor: "playground-dialog"},
        NavLink{label: "Tutorials", href: "#tutorials"},
        NavLink{label: "Docs", href: "/docs"},
        NavLink{label: "GitHub", href: "https://github.com/kukichalang/kukicha"},
    })

    hero := Hero()

    features := CardGrid(list of Feature{
        Feature{
            title: "Rename .go to .kuki. It compiles.",
            body: "Kukicha is a strict superset of Go. Your existing code works unchanged — no rewriting, no new build system, no learning curve to start.",
            href: "https://github.com/kukichalang/kukicha/blob/main/docs/kukicha-quick-reference.md",
        },
        Feature{
            title: "Blend in new features gradually",
            body: "Pipes, onerr, enums, if-expressions, readable operators. Adopt one feature at a time — leave the rest as Go. kukicha-blend shows you what's possible.",
            href: "https://github.com/kukichalang/kukicha/blob/main/docs/faq.md#coming-from-go",
        },
        Feature{
            title: "Brew it back to Go anytime",
            body: "kukicha brew converts your .kuki files to standalone, idiomatic Go. Zero lock-in — the stems dissolve, the tea remains.",
            href: "https://github.com/kukichalang/kukicha/blob/main/docs/TRANSPILER-TODO.md#2-kukicha-brew-kukicha---go-",
        },
    })

    security := CardGrid(list of Feature{
        Feature{
            title: "Security at compile time",
            body: "The compiler flags SQL injection, XSS, SSRF, path traversal, command injection, and open redirects before your code ships.",
            href: "https://github.com/kukichalang/kukicha/blob/main/docs/tutorials/production-patterns-tutorial.md",
        },
        Feature{
            title: "42+ stdlib packages",
            body: "fetch, slice, sort, mcp, llm, html, crypto, shell — batteries included for CLI tools, web apps, AI agents, and games.",
            href: "https://github.com/kukichalang/kukicha/blob/main/docs/SKILL.md",
        },
        Feature{
            title: "Ship anywhere Go runs",
            body: "Single binary. No runtime. WASM for the browser. Goroutines for concurrency. The full Go ecosystem at your fingertips.",
            href: "https://github.com/kukichalang/kukicha/blob/main/docs/tutorials/cli-explorer-tutorial.md",
        },
    })

    source := SourceReveal()
    code := CodeCompare()
    tutorials := Tutorials()
    footer := Footer()
    return html.Join(nav, hero, source, features, code, security, tutorials, footer)
