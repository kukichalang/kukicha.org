# pages/home.kuki — Landing page composition

import "stdlib/html"

func HomePage() html.Fragment
    nav := Navbar("kukicha", list of NavLink{
        NavLink{label: "Playground", dialogFor: "playground-dialog"},
        NavLink{label: "Tutorials", href: "#tutorials"},
        NavLink{label: "Docs", href: "/docs"},
        NavLink{label: "GitHub", href: "https://github.com/kukichalang/kukicha"},
    })

    hero := Hero()

    features := CardGrid(list of Feature{
        Feature{
            title: "Rename .go to .kuki. It compiles.",
            body: "Kukicha is a strict superset of Go. Your existing code works without changes. No rewriting or new build systems required.",
            href: "https://github.com/kukichalang/kukicha/blob/main/docs/kukicha-quick-reference.md",
        },
        Feature{
            title: "Adopt features gradually",
            body: "Pipes, onerr, enums, if-expressions, and readable operators. Add these to your Go code one line at a time.",
            href: "https://github.com/kukichalang/kukicha/blob/main/docs/faq.md#coming-from-go",
        },
        Feature{
            title: "Convert back to Go anytime",
            body: "The kukicha brew command converts your .kuki files into standalone, idiomatic Go. There is no vendor lock-in.",
            href: "https://github.com/kukichalang/kukicha/blob/main/docs/TRANSPILER-TODO.md#2-kukicha-brew-kukicha---go-",
        },
    })

    security := CardGrid(list of Feature{
        Feature{
            title: "Compile-time security",
            body: "The compiler detects SQL injection, XSS, SSRF, path traversal, and command injection before your code runs.",
            href: "https://github.com/kukichalang/kukicha/blob/main/docs/tutorials/production-patterns-tutorial.md",
        },
        Feature{
            title: "42+ stdlib packages",
            body: "Includes support for fetch, slice, sort, MCP, LLM, HTML, and shell commands. Built for CLI tools and AI agents.",
            href: "https://github.com/kukichalang/kukicha/blob/main/docs/SKILL.md",
        },
        Feature{
            title: "Native Go performance",
            body: "Compiles to a single binary with no runtime overhead. Built-in WASM support and Go's concurrency model.",
            href: "https://github.com/kukichalang/kukicha/blob/main/docs/tutorials/cli-explorer-tutorial.md",
        },
    })

    source := SourceReveal()
    code := CodeCompare()
    tutorials := Tutorials()
    footer := Footer()
    return html.Join(nav, hero, source, features, code, security, tutorials, footer)
