# pages/home.kuki — Landing page composition

import "stdlib/html"

func HomePage() html.Fragment
    nav := Navbar("kukicha", list of NavLink{
        NavLink{label: "Playground", dialogFor: "playground-dialog"},
        NavLink{label: "Tutorials", href: "#tutorials"},
        NavLink{label: "Docs", href: "/docs"},
        NavLink{label: "GitHub", href: "https://github.com/kukichalang/kukicha"},
    })

    hero := Hero()

    useCases := CardGrid(list of Feature{
        Feature{
            title: "AI integration",
            body: "Prompt-injection-aware LLM calls, JSON-mode decoding, and MCP servers/clients without a framework. safe.Wrap untrusted input, chat.JSONMode for structured replies, mcp for tool servers.",
            href: "https://github.com/kukichalang/kukicha/tree/main/examples/beads_kukicha",
        },
        Feature{
            title: "Cloud & deploy automation",
            body: "One static binary that drives cloud APIs from readable scripts. Drop kukicha build output onto a server and run, no runtime to install.",
            href: "https://github.com/kukichalang/kukicha/tree/main/examples/gke-django-deploy",
        },
        Feature{
            title: "Data & CLI scripting",
            body: "Pipes, concurrent.MapWithLimit, table, regex, json; the stuff you'd reach for Python or shell for, in one typed, compiled binary.",
            href: "https://github.com/kukichalang/kukicha/tree/main/examples/api-explorer",
        },
    })

    features := CardGrid(list of Feature{
        Feature{
            title: "Readable by design",
            body: "English operators, pipes that flow left-to-right, onerr for error handling, and named enums.",
            href: "https://github.com/kukichalang/kukicha/blob/main/docs/kukicha-quick-reference.md",
        },
        Feature{
            title: "Batteries included",
            body: "fetch, concurrent, llm, mcp, db, shell, html, table, color;  40+ packages with the same readable API. Reach for a stdlib package, not a third-party dependency.",
            href: "https://github.com/kukichalang/kukicha/blob/main/docs/SKILL.md#stdlib-packages",
        },
        Feature{
            title: "No lock-in",
            body: "Rename a .go file to .kuki and it mostly compiles unchanged. Run kukicha brew to convert any .kuki file back into standalone, idiomatic Go.",
            href: "https://github.com/kukichalang/kukicha#commands",
        },
    })

    security := CardGrid(list of Feature{
        Feature{
            title: "Safe by default",
            body: "Compile-time lints flag SQL injection, XSS, SSRF, path traversal, command injection, and open redirects, paired with stdlib functions (safe.Wrap, fetch.NewExternal, http.SafeHTML). Errors are values, handled with onerr.",
            href: "https://github.com/kukichalang/kukicha/blob/main/docs/SKILL.md#security--compiler-enforced-checks",
        },
        Feature{
            title: "Friendly stdlib",
            body: "fetch.GetJson, slice.Filter, concurrent.MapWithLimit, sort.ByKey, safe.Wrap, table.PrintWithStyle. Reads the same whether your code has Kukicha s or plain Go.",
            href: "https://github.com/kukichalang/kukicha/blob/main/docs/SKILL.md#stdlib-packages",
        },
        Feature{
            title: "Ships as one file",
            body: "kukicha build produces a single static binary,copy it to a server and run. Built-in WASM support, no runtime, Go's concurrency.",
            href: "https://github.com/kukichalang/kukicha#commands",
        },
    })

    source := SourceReveal()
    code := CodeCompare()
    tutorials := Tutorials()
    footer := Footer()
    return html.Join(nav, hero, useCases, source, features, code, security, tutorials, footer)
